rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper für Admin-Check (identisch mit Firestore-Logik)
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email == "info@as-mietwagen-service.de" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "as.taxi.coding@gmail.com" && request.auth.token.email_verified == true) ||
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
      );
    }

    match /gallery/{allPaths=**} {
      // Jeder darf die Bilder sehen
      allow read: if true;
      
      // Nur Admins dürfen hochladen (create/update) oder löschen (delete)
      allow write: if isAdmin();
    }
  }
}
