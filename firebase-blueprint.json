{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A ride booking or reservation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string", "format": "time" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "passengers": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pickup", "destination", "date", "time", "name", "phone", "status", "createdAt"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "A news update or announcement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date", "createdAt"]
    },
    "GuestbookEntry": {
      "title": "Guestbook Entry",
      "description": "A message left by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "rating": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "message", "rating", "date", "status", "createdAt"]
    },
    "Stats": {
      "title": "Application Stats",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "totalBookings": { "type": "number" },
        "totalVisitors": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["totalBookings", "totalVisitors", "lastUpdated"]
    }
  },
  "firestore": {
    "/bookings": {
      "schema": "Booking",
      "description": "Collection of all ride bookings."
    },
    "/news": {
      "schema": "NewsItem",
      "description": "Collection of news announcements."
    },
    "/guestbook": {
      "schema": "GuestbookEntry",
      "description": "Collection of guestbook entries."
    },
    "/stats": {
      "schema": "Stats",
      "description": "Global application statistics."
    }
  }
}
